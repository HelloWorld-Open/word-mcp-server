# ============================================
# Word MCP Server — 环境变量配置
# 复制此文件为 .env 并按需修改
# ============================================

# --- 安全策略 ---
# 允许访问的目录（分号分隔，留空=不限制）
ALLOWED_DIRECTORIES=
# 是否允许网络路径（\\server\share）
ALLOW_NETWORK_PATHS=false
# 最大文件大小（字节）
MAX_FILE_SIZE=52428800
# 最大文本长度（字符）
MAX_TEXT_LENGTH=1000000
# 是否启用宏（默认强制禁用）
ALLOW_MACROS=false
# 操作超时（毫秒）
OPERATION_TIMEOUT_MS=30000

# --- 速率限制 ---
# 时间窗口（毫秒）
RATE_LIMIT_WINDOW_MS=5000
# 窗口内最大调用次数
RATE_LIMIT_MAX_CALLS=30

# --- 看门狗 ---
# 子进程无输出超时（毫秒）
WATCHDOG_TIMEOUT_MS=30000
# 看门狗健康检查间隔（毫秒）
WATCHDOG_INTERVAL_MS=5000

# --- 图表 ---
# 图表操作超时（毫秒）
CHART_OP_TIMEOUT=15000
# 图表worker空闲超时（毫秒）
CHART_WORKER_IDLE_TIMEOUT=60000

# --- 日志 ---
# 日志级别：fatal / error / warn / info / debug / trace
LOG_LEVEL=info
